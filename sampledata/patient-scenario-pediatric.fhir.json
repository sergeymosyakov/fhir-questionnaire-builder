{
  "resourceType": "Questionnaire",
  "id": "patient-scenario-pediatric",
  "title": "Pediatric Well-Child Visit",
  "status": "draft",
  "experimental": true,
  "copyright": "© 2026 Sergey Mosyakov",
  "description": "Age-driven well-child assessment. Demonstrates calculatedExpression (BMI from height and weight), age-conditional milestone sections via enableWhenExpression, and repeating concerns. Select a Patient preset and click ↺ Re-init to populate the child profile. The correct developmental milestone section activates automatically based on age.",
  "subjectType": [
    "Patient"
  ],
  "extension": [
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "childAge",
        "language": "text/fhirpath",
        "expression": "4"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "childGender",
        "language": "text/fhirpath",
        "expression": "'female'"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "weightKg",
        "language": "text/fhirpath",
        "expression": "16.5"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "heightCm",
        "language": "text/fhirpath",
        "expression": "102"
      }
    }
  ],
  "item": [
    {
      "linkId": "how-to",
      "text": "How to use: (1) Select a Patient preset from the Patient ▾ dropdown. (2) Click ↺ Re-init. (3) The child profile and BMI fill automatically. (4) Only the age-appropriate milestone section is visible — complete it and all required fields to reach PASS.",
      "type": "display"
    },
    {
      "linkId": "child-profile",
      "text": "Child Profile (auto-filled from context)",
      "type": "group",
      "item": [
        {
          "linkId": "cp-age",
          "text": "Age (years)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%childAge"
              }
            }
          ]
        },
        {
          "linkId": "cp-gender",
          "text": "Sex",
          "type": "string",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%childGender"
              }
            }
          ]
        },
        {
          "linkId": "cp-weight",
          "text": "Weight (kg)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%weightKg"
              }
            }
          ]
        },
        {
          "linkId": "cp-height",
          "text": "Height (cm)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-initialExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%heightCm"
              }
            }
          ]
        },
        {
          "linkId": "cp-bmi",
          "text": "BMI (calculated)",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "(%weightKg / ((%heightCm / 100) * (%heightCm / 100))).round(1)"
              }
            }
          ]
        },
        {
          "linkId": "cp-head-circ",
          "text": "Head circumference (cm)",
          "type": "decimal",
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-enableWhenExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%childAge <= 2"
              }
            }
          ]
        }
      ]
    },
