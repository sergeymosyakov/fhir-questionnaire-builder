        },
        {
          "valueCoding": { "code": "weekly", "display": "1-2 times/week" },
          "extension": [
            { "url": "http://hl7.org/fhir/StructureDefinition/itemWeight", "valueDecimal": 1.5 }
          ]
        },
        {
          "valueCoding": { "code": "daily", "display": "Daily" },
          "extension": [
            { "url": "http://hl7.org/fhir/StructureDefinition/itemWeight", "valueDecimal": 3 }
          ]
        }
      ]
