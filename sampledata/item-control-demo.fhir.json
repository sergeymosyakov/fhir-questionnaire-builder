            "coding": [{ "system": "http://hl7.org/fhir/questionnaire-item-control", "code": "spinner" }]
          }
        }
      ]
    },
    {
      "linkId": "dd-default",
      "text": "Default dropdown",
      "type": "choice",
      "answerOption": [
        { "valueCoding": { "code": "x", "display": "X-ray" } },
        { "valueCoding": { "code": "y", "display": "Yankee" } }
