  "experimental": true,
  "copyright": "© 2026 Sergey Mosyakov",
  "description": "Comprehensive diabetes self-management assessment with SDC-driven risk stratification. Demonstrates the full SDC variable chain: patient context variables → calculated risk tier → conditional clinical sections (insulin vs oral meds). Select a Patient preset and click ↺ Re-init. The HbA1c Risk Tier section and medication sections switch automatically. PASS: glucose log, medication adherence, and required lifestyle fields complete. FAIL: HbA1c Risk HIGH + any required field empty.",
  "subjectType": [
    "Patient"
  ],
  "extension": [
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "age",
        "language": "text/fhirpath",
        "expression": "58"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "gender",
        "language": "text/fhirpath",
        "expression": "'male'"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "hba1c",
        "language": "text/fhirpath",
        "expression": "7.2"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "glucoseFasting",
        "language": "text/fhirpath",
        "expression": "145"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "diabetesType",
        "language": "text/fhirpath",
        "expression": "'type2'"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "onInsulin",
        "language": "text/fhirpath",
        "expression": "false"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "hba1cRisk",
        "language": "text/fhirpath",
        "expression": "iif(%hba1c >= 9, 'high', iif(%hba1c >= 7, 'moderate', 'low'))"
      }
    },
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "hba1cRiskScore",
        "language": "text/fhirpath",
        "expression": "iif(%hba1c >= 9, 3, iif(%hba1c >= 7, 1, 0))"
      }
    }
  ],
