{
  "resourceType": "Questionnaire",
  "id": "answer-expression-demo",
  "url": "http://example.org/fhir/Questionnaire/answer-expression-demo",
  "version": "1.0.0",
  "title": "Answer Expression Demo \u2014 Dynamic Option Lists",
  "status": "draft",
  "publisher": "FHIR Questionnaire Builder",
  "description": "Demonstrates sdc-questionnaire-answerExpression: answer options computed at runtime via FHIRPath. The 'Recommended Action' and 'Severity Level' questions derive their options dynamically from the PHQ-2 score.",
  "extension": [
    {
      "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
      "valueExpression": {
        "name": "phq2_score",
        "language": "text/fhirpath",
        "expression": "(%resource.item.where(linkId='phq-group').item.where(linkId='phq-q1').answer.valueCoding.extension.where(url='http://hl7.org/fhir/StructureDefinition/ordinalValue').valueDecimal | 0).first() + (%resource.item.where(linkId='phq-group').item.where(linkId='phq-q2').answer.valueCoding.extension.where(url='http://hl7.org/fhir/StructureDefinition/ordinalValue').valueDecimal | 0).first()"
      }
    }
  ],
  "item": [
    {
      "linkId": "phq-group",
      "text": "PHQ-2 Screening",
      "type": "group",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/rendering-style",
          "valueString": "font-weight:bold"
        }
      ],
      "item": [
        {
          "linkId": "phq-q1",
          "text": "Over the last 2 weeks \u2014 little interest or pleasure in doing things?",
          "type": "choice",
          "answerOption": [
            {
              "valueCoding": {
                "code": "la6568-5",
                "display": "Not at all"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 0
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6569-3",
                "display": "Several days"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 1
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6570-1",
                "display": "More than half the days"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 2
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6571-9",
                "display": "Nearly every day"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 3
                }
              ]
            }
          ]
        },
        {
          "linkId": "phq-q2",
          "text": "Over the last 2 weeks \u2014 feeling down, depressed, or hopeless?",
          "type": "choice",
          "answerOption": [
            {
              "valueCoding": {
                "code": "la6568-5",
                "display": "Not at all"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 0
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6569-3",
                "display": "Several days"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 1
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6570-1",
                "display": "More than half the days"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 2
                }
              ]
            },
            {
              "valueCoding": {
                "code": "la6571-9",
                "display": "Nearly every day"
              },
              "extension": [
                {
                  "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
                  "valueDecimal": 3
                }
              ]
            }
          ]
        },
        {
          "linkId": "phq2-score-display",
          "text": "PHQ-2 Total Score",
          "type": "decimal",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%phq2_score"
              }
            }
          ]
        }
      ]
    },
    {
      "linkId": "action-group",
      "text": "Clinical Decision Support",
      "type": "group",
      "item": [
        {
          "linkId": "severity-level",
          "text": "Severity Level (dynamic via answerExpression)",
          "type": "choice",
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-answerExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%phq2_score >= 3, 'high' | 'moderate', iif(%phq2_score >= 1, 'moderate' | 'low', 'low'))"
              }
            }
          ]
        },
        {
          "linkId": "recommended-action",
          "text": "Recommended Action (dynamic via answerExpression)",
          "type": "choice",
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-answerExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "iif(%phq2_score >= 3, 'refer-psychiatry' | 'start-antidepressant' | 'crisis-assessment', iif(%phq2_score >= 1, 'watchful-waiting' | 'counselling' | 'lifestyle-support', 'no-action-needed' | 'routine-follow-up'))"
              }
            }
          ]
        },
        {
          "linkId": "notes",
          "text": "Clinical Notes",
          "type": "text"
        }
      ]
    }
  ]
}