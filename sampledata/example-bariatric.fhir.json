    {
      "linkId": "g-field-types",
      "prefix": "9.",
      "type": "group",
      "text": "Field Types Demo",
      "item": [
        {
          "linkId": "q-notes",
          "prefix": "9.1",
          "type": "text",
          "text": "Additional clinical notes (multiline text)"
        },
        {
          "linkId": "q-weight-kg",
          "prefix": "9.2",
          "type": "decimal",
          "text": "Current weight (kg)",
          "required": true
        },
        {
          "linkId": "q-height-cm",
          "prefix": "9.3",
          "type": "decimal",
          "text": "Height (cm)",
          "required": true
        },
        {
          "linkId": "q-bmi-calc",
          "prefix": "9.4",
          "type": "decimal",
          "text": "Calculated BMI",
          "readOnly": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "(%resource.repeat(item).where(linkId='q-weight-kg').answer.valueDecimal / ((%resource.repeat(item).where(linkId='q-height-cm').answer.valueDecimal / 100) * (%resource.repeat(item).where(linkId='q-height-cm').answer.valueDecimal / 100))).round(1)"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-constraint",
              "extension": [
                {
                  "url": "key",
                  "valueId": "bmi-eligibility"
                },
                {
                  "url": "severity",
                  "valueCode": "error"
                },
                {
                  "url": "human",
                  "valueString": "Calculated BMI must be >= 35 to meet minimum bariatric surgery eligibility"
                },
                {
                  "url": "expression",
                  "valueString": "%resource.repeat(item).where(linkId='q-bmi-calc').answer.valueDecimal >= 35"
                }
              ]
            }
          ]
        },
        {
          "linkId": "q-referring-provider",
          "prefix": "9.5",
          "type": "reference",
          "text": "Referring Provider",
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-referenceResource",
              "valueCode": "Practitioner"
            }
          ]
        },
        {
          "linkId": "q-body-temp",
          "prefix": "9.6",
          "type": "quantity",
          "text": "Body temperature",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unit",
              "valueCoding": {
                "system": "http://unitsofmeasure.org",
                "code": "Cel",
                "display": "°C"
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unitValueSet",
              "valueCanonical": "http://hl7.org/fhir/ValueSet/ucum-bodytemp"
            }
          ]
        },
        {
          "linkId": "q-info-display",
          "prefix": "9.7",
          "type": "display",
          "text": "ℹ️ All documents must be uploaded before submission. Incomplete applications will not be processed."
        },
        {
          "linkId": "q-weight-preop",
          "prefix": "9.8",
          "type": "quantity",
          "text": "Pre-operative weight",
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unitOption",
              "valueCoding": { "system": "http://unitsofmeasure.org", "code": "kg", "display": "kg" }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-unitOption",
              "valueCoding": { "system": "http://unitsofmeasure.org", "code": "[lb_av]", "display": "lb" }
            }
          ]
        },
        {
          "linkId": "q-status-readonly",
          "prefix": "9.9",
          "type": "string",
          "text": "Authorization status (system-assigned)",
          "readOnly": true,
          "initial": [
            {
              "valueString": "Pending review"
            }
          ]
        }
      ]
    },
