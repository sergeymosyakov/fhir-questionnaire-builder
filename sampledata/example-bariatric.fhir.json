                  }
                ]
              }
            },
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-choiceOrientation",
              "valueCode": "horizontal"
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "code": "low-carb",
                "display": "Low Carb"
              }
            },
            {
              "valueCoding": {
                "code": "low-fat",
                "display": "Low Fat"
              }
            },
            {
              "valueCoding": {
                "code": "mediterranean",
                "display": "Mediterranean"
              }
            }
          ]
        },
        {
          "linkId": "q-support-group",
          "prefix": "8.2",
          "type": "choice",
          "text": "Willing to join support group?",
