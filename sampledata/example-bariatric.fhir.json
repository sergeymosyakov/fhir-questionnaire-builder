{
  "resourceType": "Questionnaire",
  "id": "bariatric-pre-auth",
  "title": "Bariatric Surgery Pre-Authorization Screening",
  "status": "active",
  "experimental": true,
  "copyright": "© 2026 Sergey Mosyakov",
  "subjectType": [
    "Patient"
  ],
  "date": "2024-01-01",
  "contained": [
    {
      "resourceType": "ValueSet",
      "id": "vs-comorbidities",
      "url": "http://example.org/fhir/ValueSet/bariatric-comorbidities",
      "name": "BariatricComorbidities",
      "title": "Obesity-Related Comorbidities",
      "status": "active",
      "description": "Comorbidities qualifying patients with BMI 35–39.9 for bariatric surgery",
      "compose": {
        "include": [
          {
            "system": "http://snomed.info/sct",
            "concept": [
              {
                "code": "44054006",
                "display": "Type 2 Diabetes Mellitus"
              },
              {
                "code": "38341003",
                "display": "Hypertension"
              },
              {
                "code": "78275009",
                "display": "Obstructive Sleep Apnea"
              },
              {
                "code": "235494005",
                "display": "Non-alcoholic Fatty Liver Disease / NASH"
              },
              {
                "code": "235595009",
                "display": "Gastroesophageal Reflux Disease"
              }
            ]
          }
        ]
      }
    },
    {
      "resourceType": "ValueSet",
      "id": "vs-vitamin-deficiencies",
      "url": "http://example.org/fhir/ValueSet/bariatric-vitamin-deficiencies",
      "name": "VitaminDeficiencies",
      "title": "Pre-operative Vitamin Deficiency Types",
      "status": "active",
      "compose": {
        "include": [
          {
            "system": "http://example.org/bariatric/codes",
            "concept": [
              {
                "code": "vitD",
                "display": "Vitamin D"
              },
              {
                "code": "B12",
                "display": "Vitamin B12"
              },
              {
                "code": "iron",
                "display": "Iron"
              },
              {
                "code": "folate",
                "display": "Folate"
              }
            ]
          }
        ]
      }
    }
  ],
  "item": [
    {
      "linkId": "g-eligibility",
      "prefix": "1.",
      "text": "Patient Eligibility Criteria",
      "type": "group",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-collapsible",
          "valueCode": "default-closed"
        }
      ],
      "item": [
        {
          "linkId": "q-bmi-criterion",
          "prefix": "1.1",
          "text": "BMI eligibility criterion",
          "type": "choice",
          "required": true,
          "initial": [
            {
              "valueCoding": {
                "code": "bmi40",
                "display": "BMI ≥ 40 kg/m²"
              }
            }
          ],
          "answerOption": [
            {
              "valueCoding": {
                "code": "bmi40",
                "display": "BMI ≥ 40 kg/m²"
              }
            },
            {
              "valueCoding": {
                "code": "bmi35",
                "display": "BMI 35–39.9 with serious comorbidity"
              }
            },
            {
              "valueCoding": {
                "code": "neither",
                "display": "Neither — does not meet BMI criteria"
              }
            }
          ]
        },
        {
          "linkId": "q-comorb-type",
          "prefix": "1.2",
          "text": "Primary comorbidity",
          "type": "choice",
          "required": true,
          "enableWhen": [
            {
              "question": "q-bmi-criterion",
              "operator": "=",
              "answerCoding": {
                "code": "bmi35"
              }
            }
          ],
          "answerValueSet": "#vs-comorbidities"
        }
      ]
    },
    {
      "linkId": "g-diet",
      "prefix": "2.",
      "text": "Diet & Weight-Loss History",
      "type": "group",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-collapsible",
          "valueCode": "default-open"
        }
      ],
      "item": [
        {
          "linkId": "q-diet-months",
          "prefix": "2.1",
          "text": "Months of documented supervised diet",
          "type": "integer",
          "required": true,
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-constraint",
              "extension": [
                {
                  "url": "key",
                  "valueId": "diet-min-months"
                },
                {
                  "url": "severity",
                  "valueCode": "error"
                },
                {
                  "url": "human",
                  "valueString": "At least 3 months of supervised diet required for surgery eligibility"
                },
                {
                  "url": "expression",
                  "valueString": "%resource.repeat(item).where(linkId='q-diet-months').answer.valueInteger >= 3"
                }
              ]
            }
          ],
          "initial": [
            {
              "valueInteger": 6
            }
          ]
        },
        {
          "linkId": "q-diet-program",
          "prefix": "2.2",
          "text": "Participated in a formal weight-loss program?",
          "type": "boolean",
          "required": true,
          "initial": [
            {
              "valueBoolean": false
            }
          ]
        },
        {
          "linkId": "q-program-name",
          "prefix": "2.3",
          "text": "Program name",
          "type": "string",
          "enableWhen": [
            {
              "question": "q-diet-program",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        },
        {
          "linkId": "q-preferred-surgeon",
          "prefix": "2.4",
          "text": "Preferred surgical facility (or enter your own)",
          "type": "open-choice",
          "required": false,
          "extension": [
            {
              "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-openLabel",
              "valueString": "Other facility (type name)"
            }
          ],
          "answerOption": [
            {
              "valueString": "University Medical Center"
            },
            {
              "valueString": "Regional Bariatric Institute"
            },
            {
              "valueString": "City General Hospital"
            }
          ]
        },
        {
          "linkId": "q-diet-meds",
          "prefix": "2.5",
          "text": "Anti-obesity medications tried?",
          "type": "boolean"
        },
        {
          "linkId": "q-diet-meds-lst",
          "prefix": "2.6",
          "text": "Medications (comma-separated)",
          "type": "string",
          "enableWhen": [
            {
              "question": "q-diet-meds",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        }
      ]
    },
    {
      "linkId": "g-psych",
      "prefix": "3.",
      "text": "Psychological Evaluation",
      "type": "group",
      "item": [
        {
          "linkId": "q-psych-done",
          "prefix": "3.1",
          "text": "Psychiatric evaluation completed?",
          "type": "boolean",
          "required": true,
          "initial": [
            {
              "valueBoolean": true
            }
          ]
        },
        {
          "linkId": "q-phq9",
          "prefix": "3.2",
          "text": "PHQ-9 score (0–27)",
          "type": "integer",
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-constraint",
              "extension": [
                {
                  "url": "key",
                  "valueId": "phq9-severity"
                },
                {
                  "url": "severity",
                  "valueCode": "warning"
                },
                {
                  "url": "human",
                  "valueString": "PHQ-9 >= 15 indicates moderate-to-severe depression — additional psychiatric review recommended"
                },
                {
                  "url": "expression",
                  "valueString": "%resource.repeat(item).where(linkId='q-phq9').answer.valueInteger < 15"
                }
              ]
            }
          ],
          "enableWhen": [
            {
              "question": "q-psych-done",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        },
        {
          "linkId": "q-psych-cleared",
          "prefix": "3.3",
          "text": "Cleared for surgery by psychiatrist?",
          "type": "boolean",
          "required": true,
          "enableWhen": [
            {
              "question": "q-psych-done",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        },
        {
          "linkId": "q-substance",
          "prefix": "3.4",
          "text": "History of substance use disorder?",
          "type": "boolean",
          "required": true
        },
        {
          "linkId": "q-substance-dtl",
          "prefix": "3.5",
          "text": "Details / current status",
          "type": "string",
          "enableWhen": [
            {
              "question": "q-substance",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        }
      ]
    },
    {
      "linkId": "g-nutrition",
      "prefix": "4.",
      "text": "Nutritional Assessment",
      "type": "group",
      "item": [
        {
          "linkId": "q-rd-done",
          "prefix": "4.1",
          "text": "Registered Dietitian consultation completed?",
          "type": "boolean",
          "required": true
        },
        {
          "linkId": "q-vit-def",
          "prefix": "4.2",
          "text": "Pre-operative vitamin deficiency detected?",
          "type": "boolean"
        },
        {
          "linkId": "q-vit-type",
          "prefix": "4.3",
          "text": "Deficiency type",
          "type": "choice",
          "enableWhen": [
            {
              "question": "q-vit-def",
              "operator": "=",
              "answerBoolean": true
            }
          ],
          "answerValueSet": "#vs-vitamin-deficiencies"
        }
      ]
    },
    {
      "linkId": "g-female",
      "prefix": "5.",
      "text": "Female-Specific Requirements",
      "type": "group",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-enableWhenExpression",
          "valueExpression": {
            "language": "text/fhirpath",
            "expression": "%gender = 'female'"
          }
        }
      ],
      "item": [
        {
          "linkId": "q-preg-test",
          "prefix": "5.1",
          "text": "Pregnancy test performed within 7 days?",
          "type": "boolean",
          "required": true
        },
        {
          "linkId": "q-preg-neg",
          "prefix": "5.2",
          "text": "Result: negative?",
          "type": "boolean",
          "required": true,
          "enableWhen": [
            {
              "question": "q-preg-test",
              "operator": "=",
              "answerBoolean": true
            }
          ]
        },
        {
          "linkId": "q-ocp",
          "prefix": "5.3",
          "text": "Contraception counseling provided (12-month post-op)?",
          "type": "boolean",
          "required": true
        }
      ]
    },
    {
      "linkId": "g-surgical",
      "prefix": "6.",
      "text": "Surgical Procedure Selection",
      "type": "group",
      "item": [
        {
          "linkId": "q-proc-type",
          "prefix": "6.1",
          "text": "Proposed procedure",
          "type": "choice",
          "required": true,
          "answerOption": [
            {
              "valueCoding": {
                "code": "43644",
                "display": "Laparoscopic Roux-en-Y Gastric Bypass"
              }
            },
            {
              "valueCoding": {
                "code": "43775",
                "display": "Laparoscopic Sleeve Gastrectomy"
              }
            },
            {
              "valueCoding": {
                "code": "43770",
                "display": "Laparoscopic Adjustable Gastric Band"
              }
            },
            {
              "valueCoding": {
                "code": "43845",
                "display": "Biliopancreatic Diversion with DS"
              }
            }
          ]
        },
        {
          "linkId": "q-surgeon-cert",
          "prefix": "6.2",
          "text": "Surgeon board-certified in bariatric surgery?",
          "type": "boolean",
          "required": true
        },
        {
          "linkId": "q-facility",
          "prefix": "6.3",
          "text": "Facility MBSAQIP accredited?",
          "type": "boolean",
          "required": true
        }
      ]
    },
    {
      "linkId": "g-documents",
      "prefix": "7.",
      "type": "group",
      "text": "Supporting Documents & Dates",
      "item": [
        {
          "linkId": "q-surgery-date",
          "prefix": "7.1",
          "type": "date",
          "text": "Planned Surgery Date",
          "required": true
        },
        {
          "linkId": "q-last-visit-date",
          "prefix": "7.2",
          "type": "date",
          "text": "Date of Last Clinical Visit",
          "required": true
        },
        {
          "linkId": "q-referral-url",
          "prefix": "7.3",
          "type": "url",
          "text": "Referral Document URL",
          "required": false
        },
        {
          "linkId": "q-guidelines-url",
          "prefix": "7.4",
          "type": "url",
          "text": "Clinical Guidelines Reference URL",
          "required": true
        },
        {
          "linkId": "q-referral-doc",
          "prefix": "7.5",
          "type": "attachment",
          "text": "Upload Referral Document (PDF)",
          "required": true
        },
        {
          "linkId": "q-lab-results",
          "prefix": "7.6",
          "type": "attachment",
          "text": "Upload Lab Results",
          "required": false
        }
      ]
    },
