      "linkId": "vitals",
      "text": "Vital Signs",
      "type": "group",
      "code": [
        {
          "system": "http://loinc.org",
          "code": "85353-1",
          "display": "Vital signs, weight, height, head circumference, oxygen saturation and BMI panel"
        }
      ],
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-observationExtract",
          "valueBoolean": true
        }
      ],
      "item": [
