{
  "resourceType": "Questionnaire",
  "id": "prowl-ss",
  "url": "http://example.org/fhir/Questionnaire/prowl-ss",
  "version": "1.0.0",
  "name": "PROWL_SS",
  "title": "PROWL-SS — Post-Surgical Pain Assessment",
  "status": "active",
  "copyright": "© 2026 Sergey Mosyakov",
  "experimental": true,
  "subjectType": ["Patient"],
  "date": "2024-01-01",
  "publisher": "Example Organization",
  "description": "Patient-reported outcome instrument for persistent post-surgical pain and functional impact at the surgical site (PROWL-SS).",
  "item": [
    {
      "linkId": "1",
      "text": "Pain at Surgical Site",
      "type": "group",
      "item": [
        {
          "linkId": "1.1",
          "text": "Rate your pain at the surgical site right now (0 = no pain, 10 = worst imaginable pain)",
          "type": "integer",
          "required": true
        },
        {
          "linkId": "1.2",
          "text": "Rate your WORST pain at the surgical site in the past 24 hours (0-10)",
          "type": "integer",
          "required": true
        },
        {
          "linkId": "1.3",
          "text": "Rate your pain at the surgical site during movement or activity (0-10)",
          "type": "integer"
        }
      ]
    },
    {
      "linkId": "2",
      "text": "Wound Sensations",
      "type": "group",
      "item": [
        {
          "linkId": "2.1",
          "text": "Do you experience burning sensation at the surgical site?",
          "type": "boolean"
        },
        {
          "linkId": "2.2",
          "text": "Do you experience stabbing or shooting pain at the surgical site?",
          "type": "boolean"
        },
        {
          "linkId": "2.3",
          "text": "Do you experience numbness or tingling at the surgical site?",
          "type": "boolean"
        },
        {
          "linkId": "2.4",
          "text": "Describe the predominant sensation at the surgical site",
          "type": "choice",
          "answerOption": [
            { "valueCoding": { "code": "aching",   "display": "Aching" } },
            { "valueCoding": { "code": "burning",  "display": "Burning" } },
            { "valueCoding": { "code": "stabbing", "display": "Stabbing" } },
            { "valueCoding": { "code": "throbbing","display": "Throbbing" } },
            { "valueCoding": { "code": "none",     "display": "No sensation" } }
          ]
        }
      ]
    },
    {
      "linkId": "3",
      "text": "Functional Impact",
      "type": "group",
      "item": [
        {
          "linkId": "3.1",
          "text": "Has surgical site pain interfered with your sleep in the past 24 hours?",
          "type": "choice",
          "required": true,
          "answerOption": [
            { "valueCoding": { "code": "not-at-all",  "display": "Not at all" } },
            { "valueCoding": { "code": "a-little",    "display": "A little" } },
            { "valueCoding": { "code": "moderately",  "display": "Moderately" } },
            { "valueCoding": { "code": "quite-a-bit", "display": "Quite a bit" } },
            { "valueCoding": { "code": "extremely",   "display": "Extremely" } }
          ]
        },
        {
          "linkId": "3.2",
          "text": "Has pain limited your ability to perform daily tasks?",
          "type": "choice",
          "required": true,
          "answerOption": [
            { "valueCoding": { "code": "not-at-all",  "display": "Not at all" } },
            { "valueCoding": { "code": "a-little",    "display": "A little" } },
            { "valueCoding": { "code": "moderately",  "display": "Moderately" } },
            { "valueCoding": { "code": "quite-a-bit", "display": "Quite a bit" } },
            { "valueCoding": { "code": "extremely",   "display": "Extremely" } }
          ]
        },
        {
          "linkId": "3.3",
          "text": "Have you been able to return to normal work or activities?",
          "type": "choice",
          "answerOption": [
            { "valueCoding": { "code": "fully",       "display": "Yes, fully" } },
            { "valueCoding": { "code": "partially",   "display": "Partially" } },
            { "valueCoding": { "code": "not-yet",     "display": "Not yet" } },
            { "valueCoding": { "code": "not-working", "display": "Not applicable" } }
          ]
        }
      ]
    },
    {
      "linkId": "4",
      "text": "Recovery Satisfaction",
      "type": "group",
      "item": [
        {
          "linkId": "4.1",
          "text": "How satisfied are you with your recovery so far?",
          "type": "choice",
          "required": true,
          "answerOption": [
            { "valueCoding": { "code": "very-satisfied",    "display": "Very satisfied" } },
            { "valueCoding": { "code": "satisfied",         "display": "Satisfied" } },
            { "valueCoding": { "code": "neutral",           "display": "Neutral" } },
            { "valueCoding": { "code": "dissatisfied",      "display": "Dissatisfied" } },
            { "valueCoding": { "code": "very-dissatisfied", "display": "Very dissatisfied" } }
          ]
        },
        {
          "linkId": "4.2",
          "text": "Additional comments about your recovery",
          "type": "string"
        }
      ]
    }
  ]
}
